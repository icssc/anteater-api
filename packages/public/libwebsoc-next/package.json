{
  "name": "@icssc/libwebsoc-next",
  "version": "1.1.2",
  "description": "A library for safely querying WebSoc and parsing the data into a JS object",
  "repository": {
    "type": "git",
    "url": "https://github.com/icssc/anteater-api"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup src/index.ts --clean --dts --format esm --minify",
    "check:types": "tsc -p ./tsconfig.json -noEmit",
    "prepack": "pnpm run check:types && pnpm run build"
  },
  "dependencies": {
    "cheerio": "1.2.0",
    "cross-fetch": "4.1.0",
    "fast-xml-parser": "5.9.3"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
