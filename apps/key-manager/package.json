{
  "name": "@apps/key-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "check:types": "tsc -p ./tsconfig.json -noEmit",
    "deploy": "opennextjs-cloudflare build && dotenv -- opennextjs-cloudflare deploy",
    "dev": "next dev",
    "postinstall": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "migrate": "dotenv -- tsx src/db/migrate.ts",
    "preview": "opennextjs-cloudflare build && dotenv -- opennextjs-cloudflare preview --port 3000"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "1.11.1",
    "@hookform/resolvers": "5.2.2",
    "@opennextjs/cloudflare": "^1.17.1",
    "@paralleldrive/cuid2": "3.3.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-tooltip": "1.2.8",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.1",
    "lucide-react": "0.460.0",
    "next": "16.2.1",
    "next-auth": "5.0.0-beta.30",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.72.0",
    "tailwind-merge": "3.5.0",
    "tailwindcss-animate": "1.0.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@packages/key-types": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "postcss": "8.5.8",
    "tailwindcss": "3.4.15",
    "typescript": "5.6.3",
    "wrangler": "4.76.0"
  }
}
