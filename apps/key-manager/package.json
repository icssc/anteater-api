{
  "name": "@apps/key-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "check:types": "tsc -p ./tsconfig.json -noEmit",
    "deploy": "opennextjs-cloudflare build && dotenv -- opennextjs-cloudflare deploy",
    "dev": "next dev",
    "postinstall": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "migrate": "dotenv -- tsx src/db/migrate.ts",
    "preview": "opennextjs-cloudflare build && dotenv -- opennextjs-cloudflare preview --port 3000"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "1.11.2",
    "@hookform/resolvers": "5.4.0",
    "@opennextjs/cloudflare": "^1.20.1",
    "@paralleldrive/cuid2": "3.3.0",
    "@radix-ui/react-avatar": "^1.2.1",
    "@radix-ui/react-dialog": "1.1.18",
    "@radix-ui/react-dropdown-menu": "2.1.19",
    "@radix-ui/react-label": "2.1.11",
    "@radix-ui/react-select": "2.3.2",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-switch": "1.3.2",
    "@radix-ui/react-toast": "1.2.18",
    "@radix-ui/react-tooltip": "1.2.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.23.0",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.30",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.80.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss-animate": "1.0.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@packages/key-types": "workspace:*",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "postcss": "8.5.16",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "wrangler": "4.106.0"
  }
}
